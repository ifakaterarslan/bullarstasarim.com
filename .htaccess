# Bullars Tasarım SEO ve Performance Konfigürasyonu
# Google, Bing ve Yandex başvuruları için optimize edilmiş

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 2 days"
  
  # HTML
  ExpiresByType text/html "access plus 1 day"
  
  # Resimleri 30 gün cache'le
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresDefault "access plus 30 days"
  
  # CSS, JS
  ExpiresByType text/css "access plus 14 days"
  ExpiresByType application/javascript "access plus 14 days"
  
  # Fontlar
  ExpiresByType font/ttf "access plus 365 days"
  ExpiresByType font/woff "access plus 365 days"
  ExpiresByType font/woff2 "access plus 365 days"
</IfModule>

# Gzip Compression
<IfModule mod_gzip.c>
  mod_gzip_on On
  mod_gzip_dechunk On
  mod_gzip_item_include file .(html|txt|xml|js|css|json)$
  mod_gzip_item_include handler ^cgi-script$
  mod_gzip_item_include mime ^text/.*
  mod_gzip_item_include mime ^application/x-javascript.*
  mod_gzip_item_exclude mime ^image/.*
  mod_gzip_level 6
  mod_gzip_keep_workfiles Off
</IfModule>

# UTF-8 Encoding
AddCharset UTF-8 .html .xml .css .js

# 404 Error Page
ErrorDocument 404 "Sayfa Bulunamadı - Bullars Tasarım"

# Yasak dosyalara erişimi engelle
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
